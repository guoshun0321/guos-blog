---
import { getCollection } from 'astro:content';
import BaseHead from "../../../components/BaseHead.astro";
import Header from "../../../components/Header.astro";
import Footer from "../../../components/Footer.astro";
import FormattedDate from "../../../components/FormattedDate.astro";

const posts = (await getCollection('blog'))
  .filter((p) => p.id.startsWith('openclaw/'))
  // General -> Specific (ascending)
  .sort((a, b) => a.data.pubDate.valueOf() - b.data.pubDate.valueOf());
---

<!doctype html>
<html lang="zh">
  <head>
    <BaseHead title="OpenClaw 系列" />
    <style>
      .post-list { list-style: none; padding: 0; margin: 0; display: grid; gap: 1rem; }
      .post-item { padding: 1rem; border: 1px solid rgb(var(--gray-light)); border-radius: 12px; background: rgba(255,255,255,0.7); }
      .post-title { margin: 0; font-size: 1.1rem; line-height: 1.35; }
      .post-meta { margin: 0.35rem 0 0; color: rgb(var(--gray)); font-size: 0.95rem; }
      .post-desc { margin: 0.5rem 0 0; color: rgb(var(--gray-dark)); font-size: 0.98rem; }
    </style>
  </head>
  <body>
    <Header />
    <main>
      <h1>OpenClaw 系列</h1>
      <p><a href="/">Home</a> · <a href="/en">English</a></p>

      <ul class="post-list">
        {
          posts.map((post) => (
            <li class="post-item">
              <a href={`/blog/${post.id}/`} style="text-decoration: none;">
                <h2 class="post-title">{post.data.title}</h2>
                <p class="post-meta"><FormattedDate date={post.data.pubDate} /></p>
                <p class="post-desc">{post.data.description}</p>
              </a>
            </li>
          ))
        }
      </ul>
    </main>
    <Footer />
  </body>
</html>
