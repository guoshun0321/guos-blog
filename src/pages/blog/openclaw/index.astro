---
import { getCollection } from 'astro:content';
import BaseHead from "../../../components/BaseHead.astro";
import Header from "../../../components/Header.astro";
import Footer from "../../../components/Footer.astro";
import FormattedDate from "../../../components/FormattedDate.astro";

const all = (await getCollection('blog')).filter((p) => p.id.startsWith('openclaw/'));
const byId = new Map(all.map((p) => [p.id, p]));

const sections = [
  {
    title: '总览 / 架构',
    ids: [
      'openclaw/architecture',
      'openclaw/design-structure',
      'openclaw/major-packages',
      'openclaw/major-flows',
    ],
  },
  {
    title: 'Gateway / 协议 / 通道',
    ids: [
      'openclaw/gateway-deepdive',
      'openclaw/gateway-protocol-deepdive',
      'openclaw/channels-deepdive',
      'openclaw/sessions-deepdive',
      'openclaw/memory-deepdive',
    ],
  },
  {
    title: '工具与能力',
    ids: [
      'openclaw/tools-deepdive',
      'openclaw/browser-deepdive',
      'openclaw/canvas-deepdive',
      'openclaw/nodes-deepdive',
      'openclaw/cron-deepdive',
      'openclaw/plugins-deepdive',
    ],
  },
  {
    title: '运行时与 Agent',
    ids: [
      'openclaw/runtime-structure',
      'openclaw/agents-deepdive',
    ],
  },
];

function renderList(ids) {
  return ids
    .map((id) => byId.get(id))
    .filter(Boolean);
}
---

<!doctype html>
<html lang="zh">
  <head>
    <BaseHead title="OpenClaw 系列" />
    <style>
      .post-list { list-style: none; padding: 0; margin: 0; display: grid; gap: 1rem; }
      .post-item { padding: 1rem; border: 1px solid rgb(var(--gray-light)); border-radius: 12px; background: rgba(255,255,255,0.7); }
      .post-title { margin: 0; font-size: 1.1rem; line-height: 1.35; }
      .post-meta { margin: 0.35rem 0 0; color: rgb(var(--gray)); font-size: 0.95rem; }
      .post-desc { margin: 0.5rem 0 0; color: rgb(var(--gray-dark)); font-size: 0.98rem; }
      .section { margin: 1.5rem 0 2rem; }
      .section h2 { margin: 0 0 0.75rem; }
    </style>
  </head>
  <body>
    <Header />
    <main>
      <h1>OpenClaw 系列</h1>
      <p><a href="/">Home</a> · <a href="/blog/en/openclaw/">English edition</a></p>

      {sections.map((sec) => (
        <section class="section">
          <h2>{sec.title}</h2>
          <ul class="post-list">
            {renderList(sec.ids).map((post) => (
              <li class="post-item">
                <a href={`/blog/${post.id}/`} style="text-decoration: none;">
                  <h3 class="post-title">{post.data.title}</h3>
                  <p class="post-meta"><FormattedDate date={post.data.pubDate} /></p>
                  <p class="post-desc">{post.data.description}</p>
                </a>
              </li>
            ))}
          </ul>
        </section>
      ))}

      <hr />
      <p style="color: rgb(var(--gray));">
        注：此页按“总 → 分”组织。若新增文章，请告诉我放入哪个章节。
      </p>
    </main>
    <Footer />
  </body>
</html>
